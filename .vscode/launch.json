{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run TimeTrace AI Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/timetrace-ai"
      ],
      "outFiles": [
        "${workspaceFolder}/timetrace-ai/out/**/*.js"
      ],
      "preLaunchTask": "compile:timetrace-ai"
    }
  ]
}
